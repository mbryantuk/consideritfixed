// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                     String    @id @default(cuid())
  name                   String?
  email                  String?   @unique
  emailVerified          DateTime?
  image                  String?
  role                   String    @default("USER") // USER, ADMIN
  address                String?
  latitude               Float?
  longitude              Float?
  phone                  String?
  dob                    String?
  deviceTypes            String? // e.g. "Windows PC, iPhone"
  preferredContactMethod String    @default("Email") // Email, Phone, WhatsApp
  marketingConsent       Boolean   @default(false)
  profileComplete        Boolean   @default(false)
  themePreference        String    @default("system") // system, light, dark
  largeText              Boolean   @default(false)
  highContrast           Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  accounts               Account[]
  sessions               Session[]
  requests               Request[]
  files                  UserFile[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Request {
  id            String   @id @default(cuid())
  friendlyId    String   @unique @default("REQ-0000") // Human readable ID like REQ-1234
  title         String
  description   String
  availability  String? // User's available times for call/visit
  referralCode  String? // How they heard about us
  status        String   @default("OPEN") // OPEN, IN_PROGRESS, QUOTED, AWAITING_PARTS, CLOSED
  privateNote   String? // Admin-only notes
  attachmentUrl String? // Photo of broken screen etc.
  isEmergency   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes        Quote[]
  notes         Note[]
  invoice       Invoice?
  statusLogs    RequestStatusLog[]
  partsUsed     PartUsage[]
}

model RequestStatusLog {
  id        String   @id @default(cuid())
  status    String
  createdAt DateTime @default(now())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Note {
  id            String   @id @default(cuid())
  text          String
  authorRole    String // ADMIN, USER
  attachmentUrl String? // Photo in chat
  createdAt     DateTime @default(now())
  requestId     String
  request       Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Quote {
  id        String    @id @default(cuid())
  amount    Float
  details   String
  status    String    @default("PENDING") // PENDING, ACCEPTED, REJECTED
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  requestId String
  request   Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String   @id @default(cuid())
  amount    Float
  status    String   @default("UNPAID") // UNPAID, PAID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  requestId String   @unique
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  location  String?
  text      String
  stars     Int      @default(5)
  approved  Boolean  @default(false)
  featured  Boolean  @default(false)
  videoUrl  String?  // YouTube/Vimeo embed URL
  createdAt DateTime @default(now())
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String
  postcode  String
  createdAt DateTime @default(now())

  @@unique([email, postcode])
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model UserFile {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int
  type      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String // Markdown
  excerpt   String
  category  String   @default("SCAM_ALERT") // SCAM_ALERT, TECH_TIP, LOCAL_NEWS
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KBArticle {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String // Markdown
  category  String // e.g. "Internet & Wi-Fi"
  videoUrl  String?
  published Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  eventDate   DateTime
  startTime   String?
  endTime     String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id            String   @id @default(cuid())
  title         String
  description   String
  icon          String // Lucide icon name or emoji
  estimatedTime String? // e.g. "1-2 Hours"
  featured      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PriceRate {
  id          String   @id @default(cuid())
  serviceName String
  description String
  price       String // String to allow "£40 per hr" etc
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "contact-form:127.0.0.1"
  count     Int      @default(0)
  expiresAt DateTime
}

model DiscountCode {
  id          String   @id @default(cuid())
  code        String   @unique // e.g. FELPHAM5
  description String
  percentage  Int      @default(0)
  amount      Float?   // Fixed amount if not percentage
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
}

model Part {
  id          String      @id @default(cuid())
  name        String
  description String?
  stockLevel  Int         @default(0)
  price       Float?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  usages      PartUsage[]
}

model PartUsage {
  id          String   @id @default(cuid())
  quantity    Int      @default(1)
  priceAtTime Float
  createdAt   DateTime @default(now())
  requestId   String
  request     Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  partId      String
  part        Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String // e.g. "UPDATE_REQUEST_STATUS", "CREATE_QUOTE"
  details    String? // JSON string or description
  adminId    String
  targetId   String?
  targetType String? // e.g. "Request", "User", "Invoice"
  createdAt  DateTime @default(now())
}

model WikiArticle {
  id        String   @id @default(cuid())
  title     String
  content   String // Markdown
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuickReply {
  id        String   @id @default(cuid())
  title     String
  text      String
  createdAt DateTime @default(now())
}

